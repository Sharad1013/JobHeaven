# Ignore node_modules in both frontend and backend
/frontend/node_modules/
/backend/node_modules/

# Ignore environment files
/frontend/.env
/backend/.env

# Ignore build files for frontend
/frontend/build/

# Ignore log files and other temporary files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log
